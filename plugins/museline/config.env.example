# museline config - copy this to ~/.claude/museline/config.env and edit.
# It's sourced by a shell, so use KEY="value" (no spaces around =).
# Any value you leave out falls back to the default shown here.

# --- which personality packs to mix (space-separated) --------------------------
# Options: philosophy trivia popculture witty
MUSELINE_PERSONALITIES="philosophy trivia popculture witty"

# --- how often the line changes, in seconds ------------------------------------
# Pair this with "refreshInterval" in your settings.json statusLine block.
MUSELINE_ROTATE_SECS=4

# --- show leading emoji? -------------------------------------------------------
# 1 = keep the emoji (default). 0 = strip the leading emoji and show plain text.
# Set this to 0 if your terminal renders emoji as boxes/blanks (e.g. Alacritty).
MUSELINE_EMOJI=1

# --- optional: generate fresh lines with YOUR OWN LLM key ----------------------
# Leave MUSELINE_LLM=0 to use only the curated packs (no network, always works).
# Set MUSELINE_LLM=1 to have museline periodically generate new on-theme lines in the
# background and blend them into the rotation. The statusline itself NEVER waits
# on the network - generation happens detached, and curated packs are the fallback.
MUSELINE_LLM=0

# Provider: "anthropic" (default) or "openai".
MUSELINE_PROVIDER="anthropic"

# Model (optional - sensible default per provider if omitted):
#   anthropic -> claude-haiku-4-5-20251001
#   openai    -> gpt-4o-mini
# MUSELINE_MODEL="claude-haiku-4-5-20251001"

# Where your key comes from. EITHER name an existing env var...
MUSELINE_API_KEY_ENV="ANTHROPIC_API_KEY"     # or "OPENAI_API_KEY"
# ...OR paste the key directly (less safe - prefer the env var above):
# MUSELINE_API_KEY="sk-..."

# How many lines to request per refill, and how often to refill (seconds).
MUSELINE_GEN_COUNT=15
MUSELINE_GEN_EVERY_SECS=1800
